{
  "id": "design-showcase",
  "revision": 1,
  "meta": {
    "preset": "warm-minimal",
    "description": "温暖低饱和粉彩色板，纸质触感。背景近白不刺眼，主色用珊瑚粉传递温柔但不幼稚的调性。"
  },
  "tokens": {
    "colors": {
      "description": "温暖低饱和粉彩色板，纸质触感。背景近白不刺眼，主色用珊瑚粉传递温柔但不幼稚的调性，辅助色用薄荷绿平衡甜腻感。",
      "background": "#FDFCF8",
      "foreground": "#292524",
      "primary": "#FFB7B2",
      "primary-foreground": "#292524",
      "secondary": "#E8EFE8",
      "accent": "#EFEDF4",
      "muted": "#78716C",
      "muted-foreground": "#A8A29E",
      "border": "rgba(0,0,0,0.06)",
      "card": "#FFFFFF",
      "card-foreground": "#292524",
      "destructive": "#EF4444",
      "chart": ["#FFB7B2", "#E8EFE8", "#EFEDF4", "#292524", "#78716C"]
    },
    "typography": {
      "description": "Outfit 做主字体，几何感但不冷。标题紧凑负字距制造力量感，正文宽松行距保证可读性。",
      "fontPrimary": "Outfit, sans-serif",
      "fontAccent": "Reenie Beanie, cursive",
      "fontMono": "Geist Mono, monospace",
      "scale": {
        "hero": { "size": "72px", "weight": 700, "tracking": "-0.025em", "lineHeight": 1.05 },
        "h1": { "size": "48px", "weight": 700, "tracking": "-0.025em", "lineHeight": 1.1 },
        "h2": { "size": "36px", "weight": 600, "tracking": "-0.02em", "lineHeight": 1.2 },
        "h3": { "size": "24px", "weight": 600, "tracking": "0em", "lineHeight": 1.3 },
        "body": { "size": "18px", "weight": 400, "tracking": "0em", "lineHeight": 1.6 },
        "caption": { "size": "14px", "weight": 400, "tracking": "0.01em", "lineHeight": 1.5 },
        "label": { "size": "12px", "weight": 500, "tracking": "0.05em", "lineHeight": 1.4, "textTransform": "uppercase" }
      }
    },
    "spacing": {
      "description": "宽松呼吸感。pageInset 大留白让内容悬浮在页面中央，blockGap 给每个信息块足够的停顿。",
      "unit": "8px",
      "pageInset": { "x": "80px", "y": "64px" },
      "blockGap": "32px",
      "sectionGap": "48px",
      "tight": "16px",
      "loose": "64px"
    },
    "radii": {
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "full": "9999px"
    },
    "shadows": {
      "card": "0 4px 20px -2px rgba(0,0,0,0.05)",
      "elevated": "0 8px 30px -4px rgba(0,0,0,0.08)",
      "button": "0 2px 8px -1px rgba(255,183,178,0.4)",
      "none": "none"
    },
    "effects": {
      "grain": {
        "enabled": true,
        "opacity": 0.35,
        "blendMode": "overlay",
        "turbulenceFrequency": 0.65
      }
    }
  },
  "global": {
    "description": "16:9 标准比例，近白底色配柔和渐变色团制造温暖氛围。fade 过渡不抢注意力。",
    "slideSize": { "width": 1280, "height": 720 },
    "background": {
      "color": "#FDFCF8",
      "blobs": [
        { "color": "#FFE4E1", "opacity": 0.6, "blur": "80px", "position": "top-right", "size": "40%" },
        { "color": "#E6E6FA", "opacity": 0.6, "blur": "80px", "position": "bottom-left", "size": "35%" }
      ]
    },
    "transition": "fade",
    "transitionDuration": "0.6s",
    "density": "spacious"
  },
  "pageStyles": {
    "cover": {
      "description": "封面居中大字，色团在右上角制造视觉重心偏移，让标题不至于死板居中。",
      "layout": "center",
      "title": { "font": "hero", "color": "#292524", "maxWidth": "80%" },
      "subtitle": { "font": "body", "color": "#78716C", "maxWidth": "500px", "marginTop": "24px" }
    },
    "content": {
      "description": "内容页左上对齐，标题和内容间 32px 间距让视线自然下移。",
      "layout": "top-left",
      "title": { "font": "h2", "color": "#292524", "marginBottom": "32px" },
      "body": { "font": "body", "color": "#292524" }
    },
    "section-divider": {
      "description": "章节分隔用深色反转，制造叙事节奏断点。",
      "layout": "center",
      "background": { "color": "#292524" },
      "title": { "font": "h1", "color": "#FDFCF8" },
      "subtitle": { "font": "body", "color": "#A8A29E" }
    },
    "closing": {
      "description": "结束页深色收束，CTA 用珊瑚粉按钮做唯一视觉焦点。",
      "layout": "center",
      "background": { "color": "#292524" },
      "title": { "font": "h1", "color": "#FDFCF8" }
    },
    "metrics": {
      "description": "指标页保持浅色底，让数字卡片浮起来。",
      "layout": "top-left",
      "title": { "font": "h2", "color": "#292524" }
    }
  },
  "blockStyles": {
    "statement-hero": {
      "description": "大字声明居中，大留白，珊瑚粉 label 做视觉锚点。",
      "textAlign": "center",
      "title": { "font": "hero", "color": "#292524" },
      "subtitle": { "font": "body", "color": "#78716C", "maxWidth": "600px" },
      "label": { "color": "#FFB7B2" },
      "padding": "64px"
    },
    "bullet-list": {
      "description": "要点列表用珊瑚粉圆点标记，行距紧凑但不拥挤。",
      "marker": { "type": "disc", "color": "#FFB7B2", "size": "8px" },
      "itemSpacing": "16px",
      "text": { "font": "body", "color": "#292524" },
      "heading": { "font": "label", "color": "#78716C" }
    },
    "code": {
      "description": "代码块深色背景独立于整体配色，模拟编辑器环境。",
      "background": "#1E1E2E",
      "foreground": "#CDD6F4",
      "radius": "16px",
      "padding": "24px",
      "fontSize": "14px",
      "lineHeight": 1.6,
      "titleBar": { "background": "#313244", "dotColors": ["#F38BA8", "#FAB387", "#A6E3A1"] }
    },
    "callout": {
      "description": "提示框不用边框区分变体，用背景色。大圆角让它像便签。",
      "radius": "24px",
      "padding": "24px 28px",
      "variants": {
        "info": { "background": "#EFEDF4", "titleColor": "#292524" },
        "warning": { "background": "#FEF3C7", "titleColor": "#92400E" },
        "success": { "background": "#E8EFE8", "titleColor": "#065F46" },
        "danger": { "background": "#FEE2E2", "titleColor": "#991B1B" }
      }
    },
    "metric-grid": {
      "description": "指标卡片白底浮起，数字用珊瑚粉大字做视觉冲击。",
      "background": "#FFFFFF",
      "radius": "32px",
      "shadow": "0 4px 20px -2px rgba(0,0,0,0.05)",
      "padding": "32px",
      "valueColor": "#FFB7B2",
      "labelColor": "#78716C"
    }
  },
  "animations": {},
  "overrides": []
}
