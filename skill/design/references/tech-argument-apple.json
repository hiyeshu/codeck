{
  "schemaVersion": 2,
  "root": "deck",
  "meta": {
    "title": "从工具到伙伴——子 Agent 架构的商业价值",
    "language": "zh-CN",
    "revision": 1
  },
  "elements": {
    "block-slide-cover-0-statement-hero-0": {
      "type": "StatementHero",
      "props": {
        "label": "子 Agent 架构的商业价值",
        "accent": "blue",
        "title": "你的产品卖的不是工具调用。是帮用户把事办成。",
        "body": "当你的 AI 产品还在让用户填 12 个参数时，用户想要的只是一句「帮我做个视频」。这中间的鸿沟，不是优化能填平的。"
      },
      "children": []
    },
    "slide-cover-0": {
      "type": "Slide",
      "props": {
        "purpose": "cover",
        "narrativeRole": "hook",
        "importance": "high",
        "speakerNotes": "技术论证型 deck 的封面不用产品名，用一句挑战现状的断言。label 用蓝色小字标注主题域，title 用反差制造张力（「工具调用」vs「把事办成」）。body 用一个具体场景（填 12 个参数 vs 说一句话）让抽象问题变得可感知。"
      },
      "children": [
        "block-slide-cover-0-statement-hero-0"
      ]
    },
    "block-slide-content-1-problem-card-grid-0": {
      "type": "ProblemCardGrid",
      "props": {
        "label": "问题",
        "title": "三个正在发生的事",
        "cards": [
          {
            "title": "需求越复杂，失败率越高",
            "body": "调 5 个工具、填 20 个参数。任何一步出错，整个流程崩溃。用户等 30 秒，收到报错。",
            "tone": "red"
          },
          {
            "title": "新增能力的成本指数增长",
            "body": "每接入一个新工具，就要写 Schema、调试映射、处理边界。80% 时间花在胶水代码上。",
            "tone": "orange"
          },
          {
            "title": "用户只能下达精确指令",
            "body": "听不懂「有科技感的视频」。用户必须自己选模型、填比例。这不是 AI，是表单。",
            "tone": "blue"
          }
        ]
      },
      "children": []
    },
    "slide-content-1": {
      "type": "Slide",
      "props": {
        "purpose": "content",
        "narrativeRole": "content",
        "importance": "medium",
        "speakerNotes": "问题页用 problem-card-grid 三列卡片，每张卡片一个痛点。关键技巧：标题是结论（「失败率越高」），body 是证据（「调 5 个工具、填 20 个参数」）。tone 用不同颜色区分严重程度。不要超过 3 个问题——3 是人脑最舒服的分组数。"
      },
      "children": [
        "block-slide-content-1-problem-card-grid-0"
      ]
    },
    "block-slide-comparison-2-outcome-comparison-0": {
      "type": "OutcomeComparison",
      "props": {
        "label": "对比",
        "title": "同一句话，两种结果",
        "left": {
          "label": "Skill 模式",
          "tone": "danger",
          "body": [
            "主 Agent 尝试从一句话提取 12 个参数",
            "逐个调工具，ratio 填了 vertical 而非 9:16，报错",
            "用户等 30 秒收到报错，反复三次后放弃"
          ],
          "outcome": "用户流失"
        },
        "right": {
          "label": "Agent 模式",
          "tone": "success",
          "body": [
            "主 Agent 理解意图，分派给图片处理 Agent 和视频 Agent",
            "各自自主决策、自行执行、自我修复",
            "用户一句话下单，收到 3 段视频 + 分镜脚本"
          ],
          "outcome": "用户留存"
        }
      },
      "children": []
    },
    "slide-comparison-2": {
      "type": "Slide",
      "props": {
        "purpose": "comparison",
        "narrativeRole": "content",
        "importance": "medium",
        "speakerNotes": "对比页是技术论证的核心武器。用同一个用户输入（「帮我做个视频」）展示两种架构的不同结果。左栏讲失败路径要具体到参数级别（ratio 填了 vertical），右栏讲成功路径要具体到交付物（3 段视频 + 分镜脚本）。outcome 用两个词收尾，形成最大反差。"
      },
      "children": [
        "block-slide-comparison-2-outcome-comparison-0"
      ]
    },
    "block-slide-metrics-3-dark-stat-0": {
      "type": "DarkStat",
      "props": {
        "label": "数据",
        "title": "架构选择如何影响商业指标",
        "items": [
          {
            "value": "3x",
            "label": "任务完成率提升",
            "note": "Agent 内部自愈重试，用户不再因中间步骤失败而流失",
            "color": "#5AC8FA"
          },
          {
            "value": "70%",
            "label": "接入新能力成本下降",
            "note": "新增 Agent 只需写 Prompt，无需 Schema 和胶水代码",
            "color": "#30D158"
          },
          {
            "value": "85%",
            "label": "用户操作步骤减少",
            "note": "从填 12 个参数变成说一句话",
            "color": "#FF9F0A"
          }
        ]
      },
      "children": []
    },
    "slide-metrics-3": {
      "type": "Slide",
      "props": {
        "purpose": "metrics",
        "narrativeRole": "evidence",
        "importance": "medium",
        "speakerNotes": "数据页切换到深色背景，制造视觉节奏变化，重新抓注意力。三个指标用不同颜色的大数字，每个数字下面一句话解释「为什么」。note 字段补充具体机制。不要超过 4 个指标——多了记不住。深色页在论证链中起「锚定」作用：前面讲了问题和对比，这里用数字钉死结论。"
      },
      "children": [
        "block-slide-metrics-3-dark-stat-0"
      ]
    },
    "block-slide-content-4-table-0": {
      "type": "Table",
      "props": {
        "heading": "同一个概念，每个工具说自己的方言",
        "columns": [
