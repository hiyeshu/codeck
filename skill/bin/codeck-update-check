#!/usr/bin/env bash
# codeck-update-check — periodic version check
#
# Output (one line, or nothing):
#   UPGRADE_AVAILABLE <old> <new>   — remote VERSION differs from local
#   (nothing)                       — up to date or check skipped
set -euo pipefail

CODECK_DIR="${CODECK_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="$HOME/.codeck"
CACHE_FILE="$STATE_DIR/last-update-check"
VERSION_FILE="$CODECK_DIR/VERSION"
REMOTE_URL="${CODECK_REMOTE_URL:-https://raw.githubusercontent.com/hiyeshu/codeck/main/VERSION}"

mkdir -p "$STATE_DIR"

# Skip if checked within last 4 hours
if [ -f "$CACHE_FILE" ]; then
  LAST=$(cat "$CACHE_FILE" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  DIFF=$(( NOW - LAST ))
  if [ "$DIFF" -lt 14400 ]; then
    exit 0
  fi
fi

# Read local version
LOCAL_VER=""
[ -f "$VERSION_FILE" ] && LOCAL_VER=$(cat "$VERSION_FILE" | tr -d '[:space:]')
[ -z "$LOCAL_VER" ] && exit 0

# Fetch remote version (timeout 3s, silent)
REMOTE_VER=$(curl -fsSL --connect-timeout 3 --max-time 5 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || true)

# Update cache timestamp
date +%s > "$CACHE_FILE"

# Compare
if [ -n "$REMOTE_VER" ] && [ "$REMOTE_VER" != "$LOCAL_VER" ]; then
  echo "UPGRADE_AVAILABLE $LOCAL_VER $REMOTE_VER"
fi
