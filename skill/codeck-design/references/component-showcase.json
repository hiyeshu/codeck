    "block-code-example": {
      "type": "Code",
      "props": {
        "language": "typescript",
        "title": "compiler/registry/blocks/statement-hero.ts",
        "code": "export function renderStatementHero(\n  id: string,\n  props: Record<string, unknown>\n): string {\n  const label = props.label\n    ? `<p class=\"label\">${escape(props.label)}</p>`\n    : '';\n  const title = `<h1>${escape(props.title)}</h1>`;\n  const body = props.body\n    ? `<p class=\"body\">${escape(props.body)}</p>`\n    : '';\n  return wrapBlock(id, 'statement-hero',\n    `<div class=\"statement-hero\">${label}${title}${body}</div>`\n  );\n}",
        "highlight": [6, 7, 8]
      },
      "children": []
    },

