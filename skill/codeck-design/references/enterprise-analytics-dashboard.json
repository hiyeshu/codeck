    "slide-content-4": {
      "type": "Slide",
      "props": {
        "purpose": "content",
        "narrativeRole": "content",
        "importance": "medium",
        "speakerNotes": "风险页用 problem-card-grid 聚焦需要行动的阻塞项。只放 2-3 个最关键的，不要把所有问题都列出来——决策者的注意力是稀缺资源。每张卡片的 body 要包含三个要素：现状（受阻/滞后）、原因（合规审批/缺人）、影响范围（延期 2 周/影响 3 个项目）。tone 用 red 和 orange 区分紧急程度。这页的目的不是汇报问题，是推动决策。"
      },
      "children": [
        "block-slide-content-4-problem-card-grid-0"
      ]
    },
    "block-slide-content-5-bullet-list-0": {
      "type": "BulletList",
      "props": {
        "heading": "本季度三个关键洞察",
        "items": [
          {
            "id": "insight-1",
            "title": "现场洞察加速最快",
            "body": "从 20% 到 78%，得益于 Workshop 机制的落地。建议将此模式复制到 AI 创新支柱。"
          },
          {
            "id": "insight-2",
            "title": "人文洞察在 Q3 后放缓",
            "body": "9 月达到 58% 后增速下降。根因：关键研究员离职 + 新项目排期冲突。需要补充人力。"
          },
          {
            "id": "insight-3",
            "title": "待分配积压持续增长",
            "body": "从 3 个增长到 12 个，同比 +9。如果不扩容，Q1 交付能力将成为瓶颈。"
