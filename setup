#!/bin/bash
set -e

# ─── codeck setup ───

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# ─── 注册 skills 到 Claude Code ───

CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
mkdir -p "$CLAUDE_SKILLS_DIR"

SKILLS=(
  codeck
  codeck-outline
  codeck-design
  codeck-review
  codeck-speech
  codeck-export
)

# 同时复制 CONVENTIONS.md 和 CLAUDE.md
cp "$SCRIPT_DIR/skills/CONVENTIONS.md" "$CLAUDE_SKILLS_DIR/" 2>/dev/null || true
cp "$SCRIPT_DIR/skills/CLAUDE.md" "$CLAUDE_SKILLS_DIR/" 2>/dev/null || true

for skill in "${SKILLS[@]}"; do
  target="$CLAUDE_SKILLS_DIR/$skill"
  if [ -L "$target" ] || [ ! -e "$target" ]; then
    ln -snf "$SCRIPT_DIR/skills/$skill" "$target"
  fi
done
echo "→ 已注册 ${#SKILLS[@]} 个 skill"

echo ""
echo "✓ codeck 安装完成"
echo ""
echo "使用方式:"
echo "  /codeck            dashboard"
echo "  /codeck-outline    编辑 — 收集素材，规划结构"
echo "  /codeck-design     设计师 — 生成内容 + HTML"
echo "  /codeck-review     审稿人 — 检查质量"
echo "  /codeck-speech     演讲教练 — 准备上台"
echo "  /codeck-export     出版 — PDF / PPTX"
echo ""
echo "更新方式:"
echo "  cd /path/to/codeck && git pull && ./setup"
