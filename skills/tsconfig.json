{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@codeck/core": ["../packages/core/src/index.ts"],
      "@codeck/ai": ["../packages/ai/src/index.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
